{
  "name": "smoke-layer",
  "version": "1.0.2",
  "description": "A lightweight animated smoke layer for HTML elements using Canvas 2D",
  "author": "ux-ui.pro",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ux-ui-pro/smoke-layer.git"
  },
  "bugs": {
    "url": "https://github.com/ux-ui-pro/smoke-layer/issues"
  },
  "homepage": "https://github.com/ux-ui-pro/smoke-layer",
  "sideEffects": false,
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "vite build",
    "dev": "vite",
    "verify": "npm run build && npm run lint && npm run typecheck && npm run test:smoke",
    "lint": "biome check src tests vite.config.ts",
    "lint:fix": "biome check --write src tests vite.config.ts",
    "format": "biome format --write src tests vite.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:smoke": "node --test tests/*.js",
    "prepublishOnly": "npm run clean && npm run verify"
  },
  "source": "src/index.ts",
  "main": "dist/index.cjs",
  "module": "dist/index.es.js",
  "browser": "./dist/index.umd.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.umd.js"
    },
    "./dist/*": "./dist/*"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "typescript",
    "javascript",
    "canvas",
    "canvas2d",
    "smoke",
    "fog",
    "particles",
    "animation",
    "background",
    "browser"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@types/node": "25.5.0",
    "esbuild": "0.27.4",
    "rimraf": "6.1.3",
    "typescript": "6.0.2",
    "vite": "8.0.2",
    "vite-plugin-dts": "4.5.4"
  }
}
